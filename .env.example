# Creed Space MCP Server Configuration Example

# API Configuration
CREEDSPACE_API_URL=https://api.creed.space
CREEDSPACE_API_KEY=your-api-key-here

# Default Persona (ambassador, nanny, sentinel, godparent, muse, anchor)
CREEDSPACE_DEFAULT_PERSONA=ambassador

# Analytics — OFF by default. Opt IN by setting this to 1. (DO_NOT_TRACK and CI
# are also honoured as hard-off.) Note: the analytics module is not currently
# wired into the CLI/server, so nothing is sent regardless.
CREEDSPACE_ANALYTICS_OPT_IN=0
CREEDSPACE_ANALYTICS_URL=https://api.creed.space/analytics

# Cache Configuration
CREEDSPACE_CACHE_TTL=300000
CREEDSPACE_OFFLINE_MODE=false

# Development
NODE_ENV=development
DEBUG=creedspace:*

# Do not track - respects user privacy
DO_NOT_TRACK=0